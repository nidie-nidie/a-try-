<?xml version="1.0" encoding="utf-8"?>
<mujoco model="coordinate_axes_arrows">
    <worldbody>
        <body name="arrow_container" pos="0 0 0">
            <!-- 添加固定关节 -->
            <joint type="free" limited="false"/>
            
            <!-- X轴 - 红色 -->
            <site name="x_axis_cylinder" type="cylinder" size="0.005 0.08" pos="0.04 0 0" 
                  axisangle="0 1 0 90" rgba="1 0 0 1"/>
            
            <!-- Y轴 - 绿色 -->
            <site name="y_axis_cylinder" type="cylinder" size="0.005 0.08" pos="0 0.04 0" 
                  axisangle="1 0 0 -90" rgba="0 1 0 1"/>
            
            <!-- Z轴 - 蓝色 -->
            <site name="z_axis_cylinder" type="cylinder" size="0.005 0.08" pos="0 0 0.04" 
                  rgba="0 0 1 1"/>
            
            <!-- 原点标记 -->
            <site name="origin" type="sphere" size="0.02" rgba="1 1 1 1"/>
            
            <!-- 设置极小的质量确保不受重力影响 -->
            <inertial pos="0 0 0" mass="0.000001" diaginertia="0.000001 0.000001 0.000001"/>
        </body>
    </worldbody>
</mujoco>